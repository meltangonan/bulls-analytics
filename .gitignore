# Virtual environment - don't upload (others will recreate from requirements.txt)
venv/

# Python cache files
__pycache__/
*.py[cod]
*$py.class
*.so

# Jupyter notebook checkpoints
.ipynb_checkpoints/

# Database files (can be regenerated by running scripts)
data/*.db

# Output files (generated images)
output/

# OS files
.DS_Store
Thumbs.db

# IDE settings
.vscode/
.idea/
*.swp
*.swo

# Environment variables (if we add any secrets later)
.env

